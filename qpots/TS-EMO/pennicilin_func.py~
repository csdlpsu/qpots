import torch
import numpy as np
from botorch.test_functions.multi_objective import Penicillin
from qpots.config import as_tensor


def Pennicilin_func(x):
    X = as_tensor(x)

    problem = Penicillin().to(device=X.device, dtype=X.dtype)

    result = problem.evaluate_true(X)

    return result

    
